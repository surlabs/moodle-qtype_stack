      <text>tx:rand_with_prohib(-3,3,[0,1]); /* tx=1 would cause P=C which should be avoided */
ty:rand_with_prohib(-3,3,[0]);
cx:rand_with_prohib(-1,1,[0]);
cy:rand_with_prohib(-2,2,[0]);
T(x,y):=[cx*(x+tx),cy*(y+ty)];
TF(y):=expand(ev(T(0,y)[2],x=x/cx-tx)); /* given an expression y=[fn], return a transformed y=[fn2] in new coords */
/* base off the problem with y=(x+1)^2 and y=x+3 */
A:T(-2,1);
B:T(1,4);
P:T(-1,0);
quad:TF((x+1)^2);
ta1:quad;
C:[0,ev(quad,x=0)];
line:TF(x+3);
a:A[1];
y_a:A[2];
b:B[1];
y_b:B[2];
ta2: {[a,y_a], [b,y_b]}

/*bounding box*/
bbTL:T(-3,9);
bbBR:T(2,-4);
BBx:[bbTL[1],bbBR[1],-1.5,1.5];
BBy:[bbTL[2],bbBR[2],-1.5,1.5,C[2]+cy*5]; /*including C[2] here to make sure the y-intercept is visible */
BB:[lmin(BBx),lmax(BBy),lmax(BBx),lmin(BBy)];

Delta: (a+b)^2-4*1*a*b
</text>
